{
	"name": "i18next-vue",
	"description": "i18next integration for Vue",
	"version": "5.4.0",
	"author": "Konrad Kügler <swamblumat-git@yahoo.de>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/i18next/i18next-vue.git"
	},
	"homepage": "https://github.com/i18next/i18next-vue",
	"bugs": {
		"url": "https://github.com/i18next/i18next-vue/issues"
	},
	"keywords": [
		"i18n",
		"i18next",
		"vue",
		"typescript"
	],
	"scripts": {
		"dev": "npm run build -- --watch index.ts",
		"build": "tsdown index.ts",
		"prepare": "npm run build",
		"test": "vitest",
		"test-ci": "vitest run",
		"coverage": "vitest run --coverage",
		"format": "prettier . --write"
	},
	"type": "module",
	"module": "./dist/index.mjs",
	"exports": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"peerDependencies": {
		"i18next": ">=23",
		"vue": "^3.4.38"
	},
	"devDependencies": {
		"@vitest/coverage-v8": "^4.0.16",
		"@vue/test-utils": "^2.4.6",
		"jsdom": "^27.3.0",
		"prettier": "3.7.4",
		"tsdown": "^0.18.1",
		"typescript": "^5.9.3",
		"vitest": "^4.0.16"
	},
	"files": [
		"dist/**/*"
	]
}
